# Database
DB_PATH=./snakebet.db

# App
NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=8080

# M-PESA (Production)
# Set these with real values for production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# Simulation mode (set to false for production)
SIMULATE_MPESA=true

# Next.js public URL (update this for production)
NEXT_PUBLIC_URL=https://your-domain.com
NEXT_PUBLIC_SOCKET_URL=https://your-domain.com
